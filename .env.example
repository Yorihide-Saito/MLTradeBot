# ===== Exchange (BitFlyer のみ使用) =====
EXCHANGE_TYPE=bitflyer

# ===== BitFlyer API =====
# https://lightning.bitflyer.com/developer より取得
BITFLYER_API_KEY=YOUR_BITFLYER_API_KEY
BITFLYER_SECRET_KEY=YOUR_BITFLYER_SECRET_KEY

# ===== Trading Settings =====
# BitFlyer: BTC_JPY (スポット) or FX_BTC_JPY (FX証拠金)
SYMBOL=FX_BTC_JPY
PIPS=1
# 証拠金の何割をボットに使うか (0.0 - 0.85)
AVAILABLE_MARGIN=0.5
ATR_PERIOD=14
CANDLE_INTERVAL_MINUTES=15

# ===== Paths (Docker 内パス) =====
WORK_DIR=/work

# ===== Misc =====
DEBUG=false
LOG_LEVEL=INFO

# ===== 注意: GMO Coin は使用しない =====
# OHLCV データは BitFlyer /v1/getexecutions から構築 (過去31日)
# 長期データが必要な場合:
#   1. https://www.cryptodatadownload.com/data/bitflyer/ から CSV をダウンロード
#   2. docker compose --profile retrain run retrain --csv /work/data/your_file.csv
